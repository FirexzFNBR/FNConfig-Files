{
	"FileVersion": 3,
	"Version": 1,
	"FriendlyName": "SceneGraph Tests",
	"Description": "MTF companion testing EntityFramework edge cases: lifecycle, hierarchy, error paths, integration. C++ and Verse tests.",
	"Category": "Testing",
	"EnabledByDefault": true,
	"ExplicitlyLoaded": true,
	"CanContainContent": true,
	"CanContainVerse": true,
	"VersePath": "/Fortnite.com/SceneGraphTests",
	"VerseScope": "InternalAPI",
	"Modules": [
		{
			"Name": "SceneGraphTests",
			"Type": "DeveloperTool",
			"LoadingPhase": "Default"
		}
	],
	"Plugins": [
		{
			"Name": "ModularTestFramework",
			"Enabled": true
		},
		{
			"Name": "EntityFramework",
			"Enabled": true
		},
		{
			"Name": "EntityFrameworkTests",
			"Enabled": true,
			"TargetAllowList": [ "Editor" ]
		},
		{
			"Name": "FortniteModularTestVerse",
			"Enabled": true
		},
		{
			"Name": "Solaris",
			"Enabled": true
		},
		{
			"Name": "Verse",
			"Enabled": true
		}
	]
}
