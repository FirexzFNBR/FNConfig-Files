{
	"FileVersion": 3,
	"FriendlyName": "Modular Test Framework Self-Tests",
	"Description": "Companion plugin that smoke-tests the Modular Test Framework itself.",
	"Category": "Testing",
	"IsExperimentalVersion": true,
	"CanContainContent": true,
	"EnabledByDefault": true,
	"ExplicitlyLoaded": true,
	"Modules": [
		{
			"Name": "ModularTestFrameworkTests",
			"Type": "DeveloperTool",
			"LoadingPhase": "Default"
		}
	],
	"Plugins": [
		{
			"Name": "ModularTestFramework",
			"Enabled": true
		},
		{
			"Name": "ControlFlows",
			"Enabled": true
		}
	]
}
